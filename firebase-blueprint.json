{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "Information about a user who joined the hustle (newsletter).",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Recipient email address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the subscription was created."
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers."
    }
  }
}
